{
  "mimeTypes": {
    ".gz": "application/json",
    ".json.gz": "application/json"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "globalHeaders": {
    "Cache-Control": "no-cache, no-store, must-revalidate",
    "X-Content-Type-Options": "nosniff"
  },
  "routes": [
    {
      "route": "/data/*.json.gz",
      "headers": {
        "Content-Type": "application/json",
        "Content-Encoding": "gzip",
        "Cache-Control": "no-cache"
      }
    },
    {
      "route": "/data/*.gz",
      "headers": {
        "Content-Type": "application/json",
        "Content-Encoding": "gzip",
        "Cache-Control": "no-cache"
      }
    }
  ]
}
